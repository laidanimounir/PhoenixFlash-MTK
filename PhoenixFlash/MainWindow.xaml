<Window x:Class="PhoenixFlash.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="PhoenixFlash — Outil MTK Pro"
        Height="650" Width="1000"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0a0f0a"
        TextElement.Foreground="#4CAF50"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Barre de titre -->
        <Border Grid.Row="0" Background="#0d150d" BorderBrush="#1a3a1a" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="12" Height="12" Fill="#2d3a2d" Margin="0,0,6,0"/>
                    <Ellipse Width="12" Height="12" Fill="#3a3a1a" Margin="0,0,6,0"/>
                    <Ellipse Width="12" Height="12" Fill="#1a3a1a" Margin="0,0,16,0"/>
                    <TextBlock Text="PHOENIXFLASH" FontSize="14" FontWeight="Medium"
                               Foreground="#2d7a2d" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="v1.0.0 — Outil de maintenance MTK"
                           FontSize="11" Foreground="#1a4a1a"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Navigation -->
        <Border Grid.Row="1" Background="#0b120b" BorderBrush="#1a3a1a" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="12,0">
                <Button x:Name="BtnFlash" Content="Flash" Click="BtnFlash_Click"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="#4CAF50" Margin="0,0,4,0"/>
                <Button x:Name="BtnFrp" Content="FRP Bypass" Click="BtnFrp_Click"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="#2a5a2a" Margin="0,0,4,0"/>
                <Button x:Name="BtnSettings" Content="Paramètres" Click="BtnSettings_Click"
        Style="{StaticResource MaterialDesignFlatButton}"
        Foreground="#2a5a2a"/>
                <Button x:Name="BtnSauvegarde" Content="Sauvegarde" Click="BtnSauvegarde_Click"
        Style="{StaticResource MaterialDesignFlatButton}"
        Foreground="#2a5a2a" Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Contenu principal -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#0b120b"
                    BorderBrush="#1a3a1a" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">

                        <TextBlock Text="APPAREILS" FontSize="10"
                                   Foreground="#1a5a1a" Margin="0,0,0,10"/>

                        <!-- Carte appareil -->
                        <Border Background="#0d180d" BorderBrush="#1a3a1a"
                                BorderThickness="0.5" CornerRadius="8"
                                Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Ellipse Width="7" Height="7" Fill="#2d9a2d" Margin="0,0,6,0"/>
                                    <TextBlock Text="Appareil détecté" FontSize="12"
                                               FontWeight="Medium" Foreground="#3d8a3d"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtDeviceName" Text="En attente..."
                                           FontSize="11" Foreground="#1a5a1a"/>
                                <Border Background="#0a160a" BorderBrush="#1a4a1a"
                                        BorderThickness="0.5" CornerRadius="4"
                                        Padding="4,2" Margin="0,6,0,0"
                                        HorizontalAlignment="Left">
                                    <TextBlock x:Name="TxtDeviceChip" Text="---"
                                               FontSize="10" Foreground="#2a7a2a"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Infos appareil -->
                        <Border Background="#0a160a" BorderBrush="#1a3a1a"
                                BorderThickness="0.5" CornerRadius="6"
                                Padding="8" Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="INFORMATIONS" FontSize="10"
                                           Foreground="#1a5a1a" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU"
                                               FontSize="10" Foreground="#1a5a1a" Margin="0,3"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtCpu"
                                               Text="---" FontSize="11" Foreground="#2a7a2a" Margin="0,3"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Android"
                                               FontSize="10" Foreground="#1a5a1a" Margin="0,3"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtAndroid"
                                               Text="---" FontSize="11" Foreground="#2a7a2a" Margin="0,3"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Stockage"
                                               FontSize="10" Foreground="#1a5a1a" Margin="0,3"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtStorage"
                                               Text="---" FontSize="11" Foreground="#2a7a2a" Margin="0,3"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="IMEI"
                                               FontSize="10" Foreground="#1a5a1a" Margin="0,3"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtImei"
                                               Text="---" FontSize="10" Foreground="#2a7a2a"
                                               TextWrapping="Wrap" Margin="0,3"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Série"
                                               FontSize="10" Foreground="#1a5a1a" Margin="0,3"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TxtSerial"
                                               Text="---" FontSize="10" Foreground="#2a7a2a"
                                               TextWrapping="Wrap" Margin="0,3"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Panel Flash -->
            <StackPanel x:Name="PanelFlash" Grid.Column="1" Margin="16">

                <TextBlock Text="FICHIER FIRMWARE" FontSize="10"
                           Foreground="#1a5a1a" Margin="0,0,0,8"/>

                <Border Background="#0b180b" BorderBrush="#1a4a1a" BorderThickness="0.5"
                        CornerRadius="8" Padding="14" Margin="0,0,0,16"
                        Cursor="Hand" MouseLeftButtonUp="SelectFirmware">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#0d200d" BorderBrush="#1a5a1a"
                                BorderThickness="0.5" CornerRadius="6"
                                Width="32" Height="32" Margin="0,0,12,0">
                            <TextBlock Text="📁" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtFileName"
                                       Text="Sélectionner le firmware (.bin / .zip)"
                                       FontSize="12" Foreground="#2a6a2a"/>
                            <TextBlock Text="Glisser-déposer ou cliquer pour parcourir"
                                       FontSize="10" Foreground="#1a4a1a"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="#0d200d" BorderBrush="#1a5a1a"
                                BorderThickness="0.5" CornerRadius="4" Padding="6,2">
                            <TextBlock x:Name="TxtFileSize" Text="Aucun"
                                       FontSize="10" Foreground="#2a7a2a"/>
                        </Border>
                    </Grid>
                </Border>

                <TextBlock Text="OPÉRATIONS" FontSize="10"
                           Foreground="#1a5a1a" Margin="0,0,0,8"/>
                <UniformGrid Columns="2" Margin="0,0,0,16">
                    <Button Content="Flash firmware" Click="BtnDoFlash_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            BorderBrush="#1a4a1a" Foreground="#3a8a3a"
                            Margin="0,0,4,4" Height="60"/>
                    <Button Content="Backup données" Click="BtnBackup_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            BorderBrush="#1a4a1a" Foreground="#3a8a3a"
                            Margin="4,0,0,4" Height="60"/>
                    <Button Content="Factory Reset" Click="BtnReset_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            BorderBrush="#3a2a1a" Foreground="#8a6a3a"
                            Margin="0,4,4,0" Height="60"/>
                    <Button Content="Test connexion" Click="BtnTest_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            BorderBrush="#1a4a1a" Foreground="#3a8a3a"
                            Margin="4,4,0,0" Height="60"/>
                </UniformGrid>

                <TextBlock Text="JOURNAL D'ACTIVITÉ" FontSize="10"
                           Foreground="#1a5a1a" Margin="0,0,0,8"/>
                <Border Background="#080d08" BorderBrush="#1a3a1a"
                        BorderThickness="0.5" CornerRadius="8" Height="160">
                    <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TxtLog" Padding="10"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="#2d8a2d" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- Panel FRP -->
            <StackPanel x:Name="PanelFrp" Grid.Column="1"
                        Margin="16" Visibility="Collapsed">
                <TextBlock Text="FRP BYPASS" FontSize="10"
                           Foreground="#1a5a1a" Margin="0,0,0,12"/>
                <Border Background="#150f0a" BorderBrush="#3a2a1a"
                        BorderThickness="0.5" CornerRadius="8"
                        Padding="12" Margin="0,0,0,16">
                    <TextBlock FontSize="12" Foreground="#6a5a2a" TextWrapping="Wrap"
                               Text="⚠ Utiliser uniquement sur des appareils dont vous êtes propriétaire ou avec autorisation du propriétaire."/>
                </Border>
                <Border Background="#0b180b" BorderBrush="#1a4a1a"
                        BorderThickness="0.5" CornerRadius="8"
                        Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="ÉTAPES" FontSize="10"
                                   Foreground="#1a5a1a" Margin="0,0,0,10"/>
                        <TextBlock Text="1.  Connecter l'appareil en mode EDL / Download"
                                   FontSize="12" Foreground="#2a6a2a" Margin="0,0,0,6"/>
                        <TextBlock Text="2.  Sélectionner le modèle exact dans la liste"
                                   FontSize="12" Foreground="#2a6a2a" Margin="0,0,0,6"/>
                        <TextBlock Text="3.  Lancer le bypass — durée estimée : 2 à 4 min"
                                   FontSize="12" Foreground="#2a6a2a" Margin="0,0,0,6"/>
                        <TextBlock Text="4.  Redémarrer l'appareil après l'opération"
                                   FontSize="12" Foreground="#2a6a2a"/>
                    </StackPanel>
                </Border>
                <Button Content="Lancer FRP Bypass" Click="BtnDoFrp_Click"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        BorderBrush="#2a6a2a" Foreground="#3d9a3d"
                        Height="48" Margin="0,8,0,0"/>
            </StackPanel>
            <!-- Panel Sauvegarde -->
            <ScrollViewer x:Name="PanelSauvegarde" Grid.Column="1" 
              Visibility="Collapsed"
              VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">

                    <TextBlock Text="ANALYSE DU TÉLÉPHONE" FontSize="10"
                   Foreground="#1a5a1a" Margin="0,0,0,12"/>

                    <!-- Bouton Analyser -->
                    <Button Content="Analyser le téléphone" Click="BtnAnalyser_Click"
                Style="{StaticResource MaterialDesignOutlinedButton}"
                BorderBrush="#2a6a2a" Foreground="#3d9a3d"
                Height="48" Margin="0,0,0,16"/>
                    <Button Content="Voir les photos" Click="BtnVoirPhotos_Click"
        Style="{StaticResource MaterialDesignOutlinedButton}"
        BorderBrush="#1a4a1a" Foreground="#2a7a2a"
        Height="48" Margin="0,0,0,16"/>

                    <!-- Résultats -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Photos -->
                        <Border Grid.Row="0" Grid.Column="0" Background="#0b180b"
                    BorderBrush="#1a4a1a" BorderThickness="0.5"
                    CornerRadius="8" Padding="12" Margin="0,0,4,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <CheckBox x:Name="ChkPhotos" IsChecked="True"/>
                                    <TextBlock Text="Photos" FontSize="12"
                                   Foreground="#2a6a2a" Margin="8,0,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtPhotosInfo" Text="---"
                               FontSize="11" Foreground="#1a5a1a"/>
                            </StackPanel>
                        </Border>

                        <!-- Contacts -->
                        <Border Grid.Row="0" Grid.Column="1" Background="#0b180b"
                    BorderBrush="#1a4a1a" BorderThickness="0.5"
                    CornerRadius="8" Padding="12" Margin="4,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <CheckBox x:Name="ChkContacts" IsChecked="True"/>
                                    <TextBlock Text="Contacts" FontSize="12"
                                   Foreground="#2a6a2a" Margin="8,0,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtContactsInfo" Text="---"
                               FontSize="11" Foreground="#1a5a1a"/>
                            </StackPanel>
                        </Border>

                        <!-- SMS -->
                        <Border Grid.Row="1" Grid.Column="0" Background="#0b180b"
                    BorderBrush="#1a4a1a" BorderThickness="0.5"
                    CornerRadius="8" Padding="12" Margin="0,0,4,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <CheckBox x:Name="ChkSms" IsChecked="False"/>
                                    <TextBlock Text="SMS" FontSize="12"
                                   Foreground="#2a6a2a" Margin="8,0,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtSmsInfo" Text="---"
                               FontSize="11" Foreground="#1a5a1a"/>
                            </StackPanel>
                        </Border>

                        <!-- Applications -->
                        <Border Grid.Row="1" Grid.Column="1" Background="#0b180b"
                    BorderBrush="#1a4a1a" BorderThickness="0.5"
                    CornerRadius="8" Padding="12" Margin="4,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <CheckBox x:Name="ChkApps" IsChecked="False"/>
                                    <TextBlock Text="Applications" FontSize="12"
                                   Foreground="#2a6a2a" Margin="8,0,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtAppsInfo" Text="---"
                               FontSize="11" Foreground="#1a5a1a"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Boutons Backup / Restore -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Backup sélection"
                    Click="BtnBackupSelection_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    BorderBrush="#2a6a2a" Foreground="#3d9a3d"
                    Height="48" Margin="0,0,4,0"/>
                        <Button Grid.Column="1" Content="Restore backup"
                    Click="BtnRestore_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    BorderBrush="#1a4a1a" Foreground="#2a6a2a"
                    Height="48" Margin="4,0,0,0"/>
                    </Grid>

                    <!-- Bouton Format -->
                    <Button Content="Format + Flash" Click="BtnFormatFlash_Click"
                Style="{StaticResource MaterialDesignOutlinedButton}"
                BorderBrush="#3a2a1a" Foreground="#8a6a3a"
                Height="48"/>

                </StackPanel>
            </ScrollViewer>
            <!-- Panel Paramètres -->
            <StackPanel x:Name="PanelSettings" Grid.Column="1"
                        Margin="16" Visibility="Collapsed">
                <TextBlock Text="PARAMÈTRES" FontSize="10"
                           Foreground="#1a5a1a" Margin="0,0,0,12"/>
                <Border Background="#0b180b" BorderBrush="#1a4a1a"
                        BorderThickness="0.5" CornerRadius="8"
                        Padding="12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="Vérification avant flash"
                                   FontSize="12" Foreground="#2a6a2a"/>
                        <CheckBox HorizontalAlignment="Right" IsChecked="True"/>
                    </Grid>
                </Border>
                <Border Background="#0b180b" BorderBrush="#1a4a1a"
                        BorderThickness="0.5" CornerRadius="8"
                        Padding="12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="Sauvegarde automatique"
                                   FontSize="12" Foreground="#2a6a2a"/>
                        <CheckBox HorizontalAlignment="Right" IsChecked="True"/>
                    </Grid>
                </Border>
                <Border Background="#0b180b" BorderBrush="#1a4a1a"
                        BorderThickness="0.5" CornerRadius="8"
                        Padding="12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="Mode débogage USB"
                                   FontSize="12" Foreground="#2a6a2a"/>
                        <CheckBox HorizontalAlignment="Right" IsChecked="False"/>
                    </Grid>
                </Border>
                <Border Background="#0b180b" BorderBrush="#1a4a1a"
                        BorderThickness="0.5" CornerRadius="8"
                        Padding="12">
                    <Grid>
                        <TextBlock Text="Alertes de sécurité"
                                   FontSize="12" Foreground="#2a6a2a"/>
                        <CheckBox HorizontalAlignment="Right" IsChecked="True"/>
                    </Grid>
                </Border>
            </StackPanel>

        </Grid>

        <!-- Barre de statut -->
        <Border Grid.Row="3" Background="#0a100a"
                BorderBrush="#1a3a1a" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                <Ellipse Width="5" Height="5" Fill="#2d7a2d" Margin="0,0,5,0"/>
                <TextBlock Text="Connecté" FontSize="10" Foreground="#1a5a1a" Margin="0,0,12,0"/>
                <TextBlock Text="|" FontSize="10" Foreground="#1a3a1a" Margin="0,0,12,0"/>
                <TextBlock Text="PhoenixFlash v1.0" FontSize="10" Foreground="#1a5a1a" Margin="0,0,12,0"/>
                <TextBlock Text="|" FontSize="10" Foreground="#1a3a1a" Margin="0,0,12,0"/>
                <TextBlock Text="Base: 12,400 appareils" FontSize="10" Foreground="#1a5a1a"/>
                <TextBlock x:Name="TxtClock" FontSize="10" Foreground="#1a4a2a"
                           HorizontalAlignment="Right" Margin="400,0,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>