<Window x:Class="PhoenixFlash.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:PhoenixFlash.Views"
        xmlns:sauvegarde="clr-namespace:PhoenixFlash.Views.Sauvegarde"
        Title="PhoenixFlash — Outil MTK Pro"
        Height="650" Width="1000"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBackground}"
        TextElement.Foreground="{StaticResource BrushTextPrimary}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Barre de titre -->
        <Border Grid.Row="0" Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="12" Height="12" Fill="{StaticResource BrushSuccess}" Margin="0,0,6,0"/>
                    <Ellipse Width="12" Height="12" Fill="{StaticResource BrushWarning}" Margin="0,0,6,0"/>
                    <Ellipse Width="12" Height="12" Fill="{StaticResource BrushDanger}" Margin="0,0,16,0"/>
                    <TextBlock Text="PHOENIXFLASH" FontSize="14" FontWeight="Medium"
                               Foreground="{StaticResource BrushAccent}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="v1.0.0 — Outil de maintenance MTK"
                           FontSize="11" Foreground="{StaticResource BrushTextSecondary}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Navigation -->
        <Border Grid.Row="1" Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="12,0">
                <Button x:Name="BtnFlash" Content="Flash" Click="BtnFlash_Click"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="{StaticResource BrushAccent}" Margin="0,0,4,0"/>
                <Button x:Name="BtnFrp" Content="FRP Bypass" Click="BtnFrp_Click"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="{StaticResource BrushAccent}" Margin="0,0,4,0"/>
                <Button x:Name="BtnSettings" Content="Paramètres" Click="BtnSettings_Click"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="{StaticResource BrushAccent}"/>
                <Button x:Name="BtnSauvegarde" Content="Sauvegarde" Click="BtnSauvegarde_Click"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="{StaticResource BrushAccent}" Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Contenu principal -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">

                        <TextBlock Text="APPAREILS" FontSize="10"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,10"/>

                        <!-- Carte appareil -->
                        <Border Background="{StaticResource BrushBackground}" BorderBrush="{StaticResource BrushBorder}"
                                BorderThickness="0.5" CornerRadius="8"
                                Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Ellipse Width="7" Height="7" Fill="#2d9a2d" Margin="0,0,6,0"/>
                                    <TextBlock Text="Appareil détecté" FontSize="12"
                                               FontWeight="Medium" Foreground="#3d8a3d"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtDeviceName" Text="En attente..."
                                           FontSize="11" Foreground="{StaticResource BrushTextPrimary}"/>
                                <Border Background="#0a160a" BorderBrush="#1a4a1a"
                                        BorderThickness="0.5" CornerRadius="4"
                                        Padding="4,2" Margin="0,6,0,0"
                                        HorizontalAlignment="Left">
                                    <TextBlock x:Name="TxtDeviceChip" Text="---"
                                               FontSize="10" Foreground="#2a7a2a"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Infos appareil -->
                        <Border Background="{StaticResource BrushBackground}" BorderBrush="{StaticResource BrushBorder}"
                                BorderThickness="0.5" CornerRadius="6"
                                Padding="8" Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="INFORMATIONS" FontSize="10"
                                           Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU"
                                               FontSize="10" Foreground="{StaticResource BrushTextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtCpu"
                                               Text="---" FontSize="11" Foreground="{StaticResource BrushAccent}" Margin="0,3"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Android"
                                               FontSize="10" Foreground="{StaticResource BrushTextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtAndroid"
                                               Text="---" FontSize="11" Foreground="{StaticResource BrushAccent}" Margin="0,3"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Stockage"
                                               FontSize="10" Foreground="{StaticResource BrushTextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtStorage"
                                               Text="---" FontSize="11" Foreground="{StaticResource BrushAccent}" Margin="0,3"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="IMEI"
                                               FontSize="10" Foreground="{StaticResource BrushTextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtImei"
                                               Text="---" FontSize="10" Foreground="{StaticResource BrushAccent}"
                                               TextWrapping="Wrap" Margin="0,3"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Série"
                                               FontSize="10" Foreground="{StaticResource BrushTextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TxtSerial"
                                               Text="---" FontSize="10" Foreground="{StaticResource BrushAccent}"
                                               TextWrapping="Wrap" Margin="0,3"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ✅ FIXED: All Views use correct namespaces -->
            <views:FlashView x:Name="PanelFlash" Grid.Column="1" Margin="16"/>
            <views:FrpView x:Name="PanelFrp" Grid.Column="1" Margin="16" Visibility="Collapsed"/>
            <sauvegarde:SauvegardeView x:Name="PanelSauvegarde" Grid.Column="1" Margin="16" Visibility="Collapsed"/>
            <views:ParametresView x:Name="PanelSettings" Grid.Column="1" Margin="16" Visibility="Collapsed"/>

        </Grid>

        <!-- Barre de statut -->
        <Border Grid.Row="3" Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                <Ellipse Width="5" Height="5" Fill="{StaticResource BrushSuccess}" Margin="0,0,5,0"/>
                <TextBlock Text="Connecté" FontSize="10" Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,12,0"/>
                <TextBlock Text="|" FontSize="10" Foreground="{StaticResource BrushBorder}" Margin="0,0,12,0"/>
                <TextBlock Text="PhoenixFlash v1.0" FontSize="10" Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,12,0"/>
                <TextBlock Text="|" FontSize="10" Foreground="{StaticResource BrushBorder}" Margin="0,0,12,0"/>
                <TextBlock Text="Base: 12,400 appareils" FontSize="10" Foreground="{StaticResource BrushTextSecondary}"/>
                <TextBlock x:Name="TxtClock" FontSize="10" Foreground="{StaticResource BrushAccent}"
                           HorizontalAlignment="Right" Margin="400,0,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
