<UserControl x:Class="PhoenixFlash.Views.Sauvegarde.AppelsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <CheckBox x:Name="ChkSelectAll" Content="Tout sélectionner"
                              Foreground="{StaticResource BrushTextSecondary}" FontSize="11"
                              Checked="ChkSelectAll_Changed" Unchecked="ChkSelectAll_Changed"
                              Margin="0,0,12,0"/>
                    <TextBlock x:Name="TxtCount" Text="0 appels"
                               Foreground="{StaticResource BrushTextSecondary}" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="2" Content="↻ Charger" Click="BtnLoad_Click"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="{StaticResource BrushAccent}"
                        FontSize="11" Height="28" Padding="8,0"/>
            </Grid>
        </Border>

        <!-- Liste appels -->
        <Border Grid.Row="1" Background="{StaticResource BrushBackground}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0.5"
                CornerRadius="6" Margin="0,8,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="AppelsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="0,0,0,0.5" Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <!-- Icône type appel -->
                                    <Border Grid.Column="1" Width="28" Height="28"
                                            Background="{Binding TypeColor}"
                                            CornerRadius="14" Margin="0,0,10,0">
                                        <TextBlock Text="{Binding TypeIcon}" FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Number}" FontSize="12"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   FontWeight="Medium"/>
                                        <TextBlock Text="{Binding TypeLabel}" FontSize="10"
                                                   Foreground="{Binding TypeColor}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Date}" FontSize="10"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding Duration}" FontSize="10"
                                                   Foreground="{StaticResource BrushAccent}"
                                                   HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <Button Grid.Row="2" Content="💾 Exporter journal d'appels (.ab)"
                Click="BtnBackupAppels_Click"
                Style="{StaticResource MaterialDesignOutlinedButton}"
                BorderBrush="{StaticResource BrushSuccess}"
                Foreground="{StaticResource BrushSuccess}"
                Height="36" Margin="0,8,0,0" FontSize="11"/>
    </Grid>
</UserControl>
