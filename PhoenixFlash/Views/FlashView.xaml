<UserControl x:Class="PhoenixFlash.Views.FlashView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="16">

        <TextBlock Text="FICHIER FIRMWARE" FontSize="10"
                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,8"/>

        <Border Background="{StaticResource BrushBackground}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0.5"
                CornerRadius="8" Padding="14" Margin="0,0,0,16"
                Cursor="Hand" MouseLeftButtonUp="SelectFirmware">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="0.5" CornerRadius="6"
                        Width="32" Height="32" Margin="0,0,12,0">
                    <TextBlock Text="&#x1F4C1;" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtFileName"
                               Text="Sélectionner le firmware (.bin / .zip)"
                               FontSize="12" Foreground="{StaticResource BrushAccent}"/>
                    <TextBlock Text="Glisser-déposer ou cliquer pour parcourir"
                               FontSize="10" Foreground="{StaticResource BrushTextSecondary}"/>
                </StackPanel>
                <Border Grid.Column="2" Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="0.5" CornerRadius="4" Padding="6,2">
                    <TextBlock x:Name="TxtFileSize" Text="Aucun"
                               FontSize="10" Foreground="{StaticResource BrushAccent}"/>
                </Border>
            </Grid>
        </Border>

        <TextBlock Text="OPÉRATIONS" FontSize="10"
                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,8"/>
        <UniformGrid Columns="2" Margin="0,0,0,16">
            <Button Content="Flash firmware" Click="BtnDoFlash_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    BorderBrush="{StaticResource BrushBorder}" Foreground="{StaticResource BrushAccent}"
                    Margin="0,0,4,4" Height="60"/>
            <Button Content="Backup données" Click="BtnBackup_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    BorderBrush="{StaticResource BrushBorder}" Foreground="{StaticResource BrushAccent}"
                    Margin="4,0,0,4" Height="60"/>
            <Button Content="Factory Reset" Click="BtnReset_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    BorderBrush="{StaticResource BrushWarning}" Foreground="{StaticResource BrushWarning}"
                    Margin="0,4,4,0" Height="60"/>
            <Button Content="Test connexion" Click="BtnTest_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    BorderBrush="{StaticResource BrushBorder}" Foreground="{StaticResource BrushAccent}"
                    Margin="4,4,0,0" Height="60"/>
        </UniformGrid>

        <TextBlock Text="JOURNAL D'ACTIVITÉ" FontSize="10"
                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,8"/>
        <Border Background="{StaticResource BrushBackground}" BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0.5" CornerRadius="8" Height="160">
            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="TxtLog" Padding="10"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{StaticResource BrushSuccess}" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </StackPanel>
</UserControl>
